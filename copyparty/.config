# Location: ~/.config/copyparty/<this>
[global]
#	e2dsa
#	e2ts

# ─────────────────────────────
# ACCOUNTS & GROUPS
# ─────────────────────────────

[accounts]
	perseque: marionclyderojo111
	manager: !Manager777

[groups]
	admins: perseque
	managers: perseque, manager

# ─────────────────────────────
# PUBLIC MOUNTS
# ─────────────────────────────

[/Public]
	$HOME/Public
	accs:
		A: @admins
		w: @managers
        r: *

[/Public/Documents]
	$HOME/Public/Documents
	accs:
		A: @admins
		rw: *  # read/upload for everyone, documents ra bitaw ni

[/Public/Music]
	$HOME/Public/Music
	accs:
		A: @admins
		rw: *  # read/upload for everyone, music ra bitaw ni

[/Public/Memes]
	$HOME/Public/Memes
	accs:
		A: @admins
		rw: *

# ─────────────────────────────
# PRIVATE MOUNTS (ADMINS ONLY) TRUSTED PERSONEL ONLY!!!
# ─────────────────────────────

[/Private]
    $HOME/Private
    accs:
        A: perseque

[/Private/documents]
	$HOME/Documents
    accs:
        A: perseque

[/Private/downloads]
	$HOME/Downloads
    accs:
        A: perseque
    flags:
        noidx: Games$|.*\.iso

[/Private/music]
	$HOME/Music
    accs:
        A: perseque

[/Private/pictures]
	$HOME/Pictures
    accs:
        A: perseque

[/Private/videos]
	$HOME/Videos
    accs:
        A: perseque
